---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
---
<title>About Me</title>
<MainLayout>
	<section class="pt-32 pb-20">
		<div class="container-custom">
			<div class="max-w-2xl mx-auto text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold mb-4">About Me</h1>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<img
						src="/images/profile.webp"
						alt="Profile image"
						class="w-full h-auto rounded-lg shadow-lg border-8 my-4 border-white md:p-4"
						width="720"
						height="720"
					/>
				</div>

				<div class="prose text-gray-700 mb-6">
					<h2>Hi, I'm Romane!</h2>
					<p>I'm a 25 years old Concept Artist currently living in Paris, France.
						<br>I specialize in stylized character and creature design, and I'm open for work!
					</p>
					<a href="/CV/CV.pdf">Resume</a>
					<p>Graduate from <a href="https://new3dgeconceptart.com/">New3dge Concept Art</a><br>
						Draft Selection for the <a href="https://www.therookies.co/entries/22672">Rookies 2023</a><br>
						2023 - Character Concept Artist for Capsule Studio
					</p>
				</div>
			</div>
		</div>
	</section>
</MainLayout>
