---
import siteConfig from '../../site.config.mjs';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
---

<div class="absolute left-0 right-0 z-0">
	<div class="text-center mb-12 relative z-10">
		<img
			src=`${base}/images/home_image.png`
			alt="Home Image"
			class="block mx-auto mb-10 w-full max-w-md h-auto object-contain"
		/>
		<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
			{owner}
		</h1>
		<p class="mt-4 text-base md:text-lg text-gray-700">CHARACTERS • CREATURES • PROPS</p>
		<a
			href=`${base}/collections`
			class="mt-8 inline-block px-6 py-3 bg-[#eead13] border-2 border-[#eead13] rounded-md
                      hover:bg-black hover:text-white transition-all duration-300 hover:border-black hover:shadow-md
                      text-sm md:text-base font-medium
                      transform hover:scale-105 active:scale-95"
		>
			View Gallery
		</a>
	</div>
</div>
